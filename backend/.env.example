# Backend Environment Variables
DATABASE_URL=postgresql+asyncpg://sbom:sbom_password@localhost:5432/sbom_risk_scorer
SYNC_DATABASE_URL=postgresql://sbom:sbom_password@localhost:5432/sbom_risk_scorer
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# GitHub API (required for maintenance analysis, 5000 req/hr with token)
GITHUB_TOKEN=

# Google Gemini API (required for AI remediation summaries)
GEMINI_API_KEY=

# File storage path for uploaded SBOMs
SBOM_STORAGE_PATH=./storage/sboms

# App settings
API_V1_PREFIX=/api/v1
DEBUG=true
